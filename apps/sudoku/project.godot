; Engine configuration file.
; Godot 4.x — Menagerie 小游戏合集工程（monorepo 内唯一 project.godot；目录名 apps/sudoku 为历史沿用）

config_version=5

[application]

config/name="Menagerie"
config/description="Menagerie mini-games collection (Sudoku and more in one Godot project). Export HTML5/desktop/mobile from this folder."
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameSettings="*res://scripts/game_settings.gd"

[gui]

theme/default_font="res://fonts/NotoSansSC-Regular.otf"
theme/default_font_size=17

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[internationalization]

locale/translations=PackedStringArray("res://localization/translations.csv")
locale/fallback="zh_CN"

[rendering]

renderer/rendering_method="forward_plus"
